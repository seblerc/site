<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <title>Site Haritası</title>
  <style>
    body { font-family: Arial; }
    ul { list-style-type: none; padding-left: 20px; }
    ul ul { border-left: 2px solid #ccc; margin-left: 10px; padding-left: 10px; }
    li { margin: 5px 0; }
    a { text-decoration: none; color: #007BFF; }
  </style>
</head>
<body>
  <h2>🗺️ Site Haritası</h2>
  <ul>
    <li><a href="/">Anasayfa</a>
      <ul>
        <li><a href="/galeri">Galeri</a></li>
        
        </li>
        <li>Kategoriler
          <ul>
            <% kategoriler.forEach(k => { %>
              <li><a href="/kategori/<%= k.id %>"><%= k.isim %></a></li>
            <% }) %>
          </ul>
        </li>
        <li>Haberler
          <ul>
            <% haberler.forEach(h => { %>
              <li><a href="/haber/<%= h.slug %>"><%= h.baslik %></a></li>
            <% }) %>
          </ul>
        </li>
        <li><a href="/login">Giriş Yap</a></li>
        <li><a href="/register">Kayıt Ol</a></li>
        
      </ul>
    </li>
  </ul>
</body>
</html>