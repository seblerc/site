<style>
  .ust-bar {
    max-width: 1000px;
    margin: 30px auto 10px;
    font-family: Arial, sans-serif;
    display: flex;
    justify-content: space-between;
    align-items: center;
    
  }

  .bildirim-container {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.bildirim-badge {
  position: absolute;
  top: -3px;
  right: -3px;
  background-color: red;
  border-radius: 50%;
  width: 10px;
  height: 10px;
  display: none;
}

  .bildirim-icon {
    cursor: pointer;
    font-size: 22px;
  }

  .bildirim-container.has-bildirim .bildirim-badge {
    display: inline-block;
  }

  .bildirim-container.has-bildirim::after {
  content: '';
  position: absolute;
  top: -2px;
  right: -2px;
  width: 10px;
  height: 10px;
  background: red;
  border-radius: 50%;
}
  .bildirim-popup {
  display: none;
  position: absolute;
  top: 30px;
  right: 0;
  background: #f9f9f9;
  border: 1px solid #ccc;
  border-radius: 6px;
  width: 300px;
  z-index: 100;
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  padding: 10px;
}

  .bildirim-popup h4 {
    margin-top: 0;
  }

  .bildirim-popup ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .bildirim-popup li {
    padding: 6px 0;
    border-bottom: 1px solid #eee;
  }

  .duyuru-kutusu {
    max-width: 1000px;
    margin: 20px auto;
    background: #fffbe5;
    border: 1px solid #ffd700;
    border-radius: 8px;
    padding: 15px;
    font-family: Arial, sans-serif;
  }

  .haber-listesi {
    max-width: 1000px;
    margin: 0 auto 50px;
    font-family: Arial, sans-serif;
  }

  .haber {
    display: flex;
    gap: 20px;
    border: 1px solid #ccc;
    border-radius: 8px;
    padding: 15px;
    margin-bottom: 25px;
    background: #fff;
    align-items: flex-start;
    min-height: 200px;
  }

  .haber img {
    width: 300px;
    height: 200px;
    border-radius: 5px;
    object-fit: cover;
    cursor: pointer;
  }

  .haber .icerik h3 {
    margin: 0 0 10px;
    font-size: 24px;
  }

  .haber .icerik p {
    font-size: 16px;
    margin-bottom: 10px;
  }

  .haber .icerik a {
    text-decoration: underline;
    color: #333;
  }
</style>

<style>
  .logo-container {
    position: absolute;
    top: 10px;
    left: 15px;
    z-index: 200;
  }

  .logo-container img {
    height: 38px;
    width: auto;
    transition: transform 0.2s ease;
    cursor: pointer;
  }

  .logo-container img:hover {
    transform: scale(1.05);
  }
</style>

<a href="/" class="logo-container">
  <img src="/uploads/logo.png" alt="Site Logosu">
</a>

<style>
  .bilgi-bar {
    background: #f0f0f0;
    font-family: Arial, sans-serif;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    padding: 6px 15px;
    gap: 15px;
    font-size: 14px;
    border-bottom: 1px solid #ccc;
  }

  .link-bar a {
    text-decoration: none;
    color: #333;
    font-weight: bold;
    position: relative;
    transition: color 0.3s ease;
  }

  .link-bar a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 0;
    height: 2px;
    background-color: #6c63ff;
    transition: width 0.3s ease;
  }

  .link-bar a:hover {
    color: #6c63ff;
  }

  .link-bar a:hover::after {
    width: 100%;
  }

  .bilgi-bar span {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .saat-kutu {
    background-color: #1d4f91;
    color: white;
    padding: 2px 8px;
    border-radius: 4px;
    font-weight: bold;
  }

  .yesil { color: green; }
  .kirmizi { color: red; }
</style>

<div class="bilgi-bar">
  <span>🌤️ <span id="havaDurumu">Yükleniyor...</span></span>
  <span class="vakit-kapsayici">🕌 Sabah: <span class="saat-kutu" data-saat="04:12">04:12</span></span>
<span class="vakit-kapsayici">🕌 Öğle: <span class="saat-kutu" data-saat="12:47">12:47</span></span>
<span class="vakit-kapsayici">🕌 İkindi: <span class="saat-kutu" data-saat="16:28">16:28</span></span>
<span class="vakit-kapsayici">🕌 Akşam: <span class="saat-kutu" data-saat="20:15">20:15</span></span>
<span class="vakit-kapsayici">🕌 Yatsı: <span class="saat-kutu" data-saat="21:42">21:42</span></span>
  <span>Bist <span class="yesil">▲ 9.668,36</span></span>
  <span>Dolar <span class="kirmizi">▼ 38,8447</span></span>
  <span>Euro <span class="yesil">▲ 43,7475</span></span>
  <span>Altın <span class="yesil">▲ 4.041,848</span></span>
  <span>Bitcoin <span class="kirmizi">▼ $104.535</span></span>
</div>

<div class="ust-bar">
  <div>
    <h1>📰 Welcome</h1>
    <% if (kullanici) { %>
  <p>Giriş yapan: 👤 <%= kullanici.isim %> (<%= kullanici.rol %>)</p>
  <div class="link-bar">
  <a href="/profil"> 🧑 My Profile  </a> |
  <a href="/logout"> 🔐 Logout  </a>
  | <a href="/favorilerim">💖 Favorites</a>
  <% if (kullanici.rol === 'admin') { %>
    | <a href="/admin">🛠️ Admin Panel </a>
    | <a href="/admin/ekle">📤 Haber/Duyuru Ekle </a>
  <% } %>
<% } else { %>
  <div class="link-bar">
  <a href="/login">🔓 Login</a> |
  <a href="/register">📝 Register</a>
<% } %>
| <a href="/galeri">🖼️ Gallery</a>
<div>
  </div>
<% if (kullanici) { %>
  <div class="bildirim-container <%= bildirimler.length > 0 ? 'has-bildirim' : '' %>">
    <span class="bildirim-icon" onclick="togglePopup()">🔔</span>
    <span class="bildirim-badge"></span>
    <div class="bildirim-popup" id="bildirimKutusu">
      <div style="display: flex; justify-content: space-between; align-items: center;">
        <h4>📢 Notifications</h4>
        <span onclick="togglePopup()" style="cursor: pointer; font-weight: bold;">❌</span>
      </div>
      <ul>
        <% bildirimler.forEach(b => { %>
          <li>
            <% if (b.tur === 'haber') { %>
              <a href="/haber/<%= b.slug %>" style="text-decoration: none; color: #333;">
                <%= b.mesaj %> <span style="font-size: 12px; color: #888;">(haber)</span>
              </a>
            <% } else { %>
              <%= b.mesaj %> <span style="font-size: 12px; color: #888;">(duyuru)</span>
            <% } %>
          </li>
        <% }) %>
      </ul>
    </div>
  </div>
<% } %>
<script>
  // Sayfa yüklendiğinde çalışır
  window.onload = function () {
    const container = document.querySelector('.bildirim-container');
    const gorulduMu = localStorage.getItem('bildirimGoruldu');

    if (!gorulduMu) {
      container.classList.add('has-bildirim'); // Kırmızı nokta göster
    }
  };

  function togglePopup() {
    const popup = document.getElementById('bildirimKutusu');
    const container = document.querySelector('.bildirim-container');

    popup.style.display = (popup.style.display === 'block') ? 'none' : 'block';

    if (popup.style.display === 'block') {
      container.classList.remove('has-bildirim');
      localStorage.setItem('bildirimGoruldu', 'true');
    }
  }
</script>

<hr>
<div style="max-width: 1000px; margin: auto; display: flex; justify-content: center; flex-wrap: wrap; gap: 10px; margin-bottom: 20px;">
  <a href="/" style="padding: 8px 15px; background: #d9f7d6; border-radius: 5px; text-decoration: none; color: #333; border: 1px solid #a2cfa1; font-weight: bold;">🏠 Anasayfa</a>

  <% kategoriler.forEach(k => { %>
    <a href="/kategori/<%= k.id %>" style="padding: 8px 15px; background: #f5f5f5; border-radius: 5px; text-decoration: none; color: #333; border: 1px solid #ccc;">
      <%= k.isim %>
    </a>
  <% }) %>
</div>
<% if (duyurular.length > 0) { %>
  <div class="duyuru-kutusu">
    <h3>📣 Latest Announcements</h3>
    <ul>
      <% duyurular.forEach(d => { %>
        <li><strong><%= d.baslik %>:</strong> <%= d.icerik %></li>
      <% }) %>
    </ul>
  </div>
<% } %>

<div class="haber-listesi">
  <h2>🗞️ Latest News</h2>

  <% haberler.forEach(haber => { %>
    <div class="haber">
      <a href="/haber/<%= haber.slug %>">
        <img src="<%= haber.resim %>" alt="<%= haber.baslik %>">
      </a>
      <div class="icerik">
        <h3><%= haber.baslik %></h3>
        <p><strong>Kategori:</strong> <%= haber.kategori_adi %></p>
        <p><%- haber.icerik.replace(/<[^>]+>/g, '').substring(0, 200) %>...</p>
        <a href="/haber/<%= haber.slug %>">Devamını oku →</a>
      </div>
    </div>
  <% }) %>
</div>

<script>
  // SAMSUN hava durumu (open-meteo ücretsiz ve key istemez)
  fetch("https://api.open-meteo.com/v1/forecast?latitude=41.2867&longitude=36.33&current_weather=true")
    .then(res => res.json())
    .then(data => {
      const temp = data.current_weather.temperature;
      const icon = "🌡️";
      document.getElementById("havaDurumu").innerText = ${icon} ${temp}°C;
    })
    .catch(() => {
      document.getElementById("havaDurumu").innerText = "☁️ Hava bilgisi yok";
    });
</script>

<script>
  function parseSaat(saatStr) {
    const [saat, dakika] = saatStr.split(":").map(Number);
    const hedef = new Date();
    hedef.setHours(saat, dakika, 0, 0);
    return hedef;
  }

  function guncelVakitSec() {
    const simdi = new Date();
    const vakitler = document.querySelectorAll(".saat-kutu");
    let sonraki = null;

    vakitler.forEach(kutu => {
      const hedefZaman = parseSaat(kutu.dataset.saat);
      if (!sonraki && hedefZaman > simdi) {
        sonraki = kutu;
      }
    });

    if (!sonraki) {
      // Hepsi geçtiyse sabahı göster
      sonraki = vakitler[0];
    }

    // Tüm kapsayıcıları gizle, sadece seçileni göster
    document.querySelectorAll(".vakit-kapsayici").forEach(span => {
      span.style.display = "none";
    });

    sonraki.parentElement.style.display = "flex";
    sonraki.style.backgroundColor = '#ff9900';
    sonraki.style.color = 'white';
  }

  guncelVakitSec();
</script>

<div style="text-align: center; margin-top: 15px;">
  👥 Total Visitors: <span id="toplam">...</span> |
  🟢 Online: <span id="online">...</span>
</div>

<script>
  fetch("/istatistik")
    .then(res => res.json())
    .then(data => {
      document.getElementById("toplam").textContent = data.toplam;
      document.getElementById("online").textContent = data.online;
    });
</script>