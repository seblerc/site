<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>📰 Modern News Portal</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
    body {
      margin: 0;
      padding: 0;
      background: #f4f6f8;
      font-family: 'Segoe UI', sans-serif;
    }

    .bilgi-bar {
      background: linear-gradient(to right, #f7f7f7, #f0f0f0);
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      align-items: center;
      padding: 10px 20px;
      gap: 20px;
      font-size: 14px;
      border-bottom: 1px solid #ddd;
      box-shadow: 0 2px 8px rgba(0,0,0,0.03);
    }

    .saat-kutu {
      background-color: #6c63ff;
      color: white;
      padding: 2px 10px;
      border-radius: 6px;
      font-weight: 600;
      font-size: 13px;
    }

    .kategori-bar {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 10px;
      margin: 30px auto 20px;
      max-width: 1000px;
    }

    .kategori-bar a {
      padding: 10px 18px;
      background: #f5f7ff;
      border-radius: 30px;
      text-decoration: none;
      font-weight: 500;
      border: 1px solid #ccc;
      color: #444;
      transition: background 0.3s ease, color 0.3s ease;
    }

    .kategori-bar a:hover {
      background: #6c63ff;
      color: white;
    }

    .duyuru-kutusu {
      max-width: 1000px;
      margin: 30px auto;
      background: #fffaf0;
      border: 1px solid #ffe58f;
      border-radius: 12px;
      padding: 20px 25px;
      box-shadow: 0 3px 12px rgba(255, 215, 0, 0.2);
    }

    .duyuru-kutusu h3 {
      font-size: 22px;
      margin-bottom: 15px;
    }

    .duyuru-kutusu li {
      padding: 8px 0;
      font-size: 16px;
    }

    .haber-listesi {
      max-width: 1000px;
      margin: 0 auto 50px;
    }

    .haber {
      display: flex;
      flex-direction: row;
      gap: 20px;
      background: #ffffff;
      border: 1px solid #eee;
      border-radius: 12px;
      box-shadow: 0 4px 14px rgba(0, 0, 0, 0.05);
      padding: 20px;
      margin-bottom: 25px;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .haber:hover {
      transform: translateY(-4px);
      box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
    }

    .haber img {
      width: 280px;
      height: 180px;
      border-radius: 8px;
      object-fit: cover;
    }

    .haber .icerik h3 {
      font-size: 22px;
      margin-bottom: 10px;
      color: #222;
    }

    .haber .icerik p {
      font-size: 15px;
      color: #555;
    }

    .haber .icerik a {
      display: inline-block;
      margin-top: 5px;
      color: #6c63ff;
      font-weight: 500;
      text-decoration: none;
      transition: color 0.3s ease;
    }

    .haber .icerik a:hover {
      color: #4d3fe0;
    }

    .istatistik {
      text-align: center;
      margin-top: 15px;
      font-size: 15px;
      color: #666;
    }
    @media (max-width: 768px) {
  .bilgi-bar {
    flex-direction: column;
    gap: 10px;
    padding: 10px;
    font-size: 13px;
  }

  .kategori-bar {
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .kategori-bar a {
    width: 90%;
    text-align: center;
    padding: 12px;
    font-size: 16px;
  }

  .duyuru-kutusu {
    margin: 20px 10px;
    padding: 15px;
  }

  .haber {
    flex-direction: column;
    align-items: center;
    padding: 15px;
  }

  .haber img {
    width: 100%;
    height: auto;
  }

  .haber .icerik {
    text-align: center;
  }

  .haber .icerik h3 {
    font-size: 20px;
  }

  .haber .icerik p {
    font-size: 14px;
  }

  .istatistik {
    font-size: 14px;
    padding: 10px;
  }
}
  </style>
</head>
<body>

  <!-- Bilgi Barı -->
  <div class="bilgi-bar">
    <span>🌤️ <span id="havaDurumu">Loading...</span></span>
    <span class="vakit-kapsayici">🕌 Fajr: <span class="saat-kutu" data-saat="04:12">04:12</span></span>
    <span class="vakit-kapsayici">🕌 Dhuhr: <span class="saat-kutu" data-saat="12:47">12:47</span></span>
    <span class="vakit-kapsayici">🕌 Asr: <span class="saat-kutu" data-saat="16:28">16:28</span></span>
    <span class="vakit-kapsayici">🕌 Maghrib: <span class="saat-kutu" data-saat="20:15">20:15</span></span>
    <span class="vakit-kapsayici">🕌 Isha: <span class="saat-kutu" data-saat="21:42">21:42</span></span>
    <span>BIST <span class="yesil">▲ 9,668.36</span></span>
    <span>USD <span class="kirmizi">▼ 38.8447</span></span>
    <span>EUR <span class="yesil">▲ 43.7475</span></span>
    <span>Gold <span class="yesil">▲ 4,041.848</span></span>
    <span>Bitcoin <span class="kirmizi">▼ $104,535</span></span>
  </div>

  <!-- Kategoriler -->
  <div class="kategori-bar">
    <a href="/">🏠 Home</a>
    <% kategoriler.forEach(k => { %>
      <a href="/kategori/<%= k.id %>"><%= k.isim %></a>
    <% }) %>
  </div>

  <!-- Duyurular -->
  <% if (duyurular.length > 0) { %>
    <div class="duyuru-kutusu">
      <h3>📣 Latest Announcements</h3>
      <ul>
        <% duyurular.forEach(d => { %>
          <li><strong><%= d.baslik %>:</strong> <%= d.icerik %></li>
        <% }) %>
      </ul>
    </div>
  <% } %>

  <!-- Haberler -->
  <div class="haber-listesi">
    <h2 style="text-align:center; font-size:26px; color:#222;">🗞️ Latest News</h2>

    <% haberler.forEach(haber => { %>
      <div class="haber">
        <a href="/haber/<%= haber.slug %>">
          <img src="<%= haber.resim %>" alt="<%= haber.baslik %>">
        </a>
        <div class="icerik">
          <h3><%= haber.baslik %></h3>
          <p><strong>Category:</strong> <%= haber.kategori_adi %></p>
          <p><%- haber.icerik.replace(/<[^>]+>/g, '').substring(0, 200) %>...</p>
          <a href="/haber/<%= haber.slug %>">Read more →</a>
        </div>
      </div>
    <% }) %>
  </div>

  <!-- Ziyaretçi Sayacı -->
  <div class="istatistik">
    👥 Total Visitors: <span id="toplam">...</span> |
    🟢 Online: <span id="online">...</span>
  </div>

  <!-- Scriptler -->
  <script>
    fetch("https://api.open-meteo.com/v1/forecast?latitude=41.2867&longitude=36.33&current_weather=true")
      .then(res => res.json())
      .then(data => {
        const temp = data.current_weather.temperature;
        const icon = "🌡️";
        document.getElementById("havaDurumu").innerText = `${icon} ${temp}°C`;
      })
      .catch(() => {
        document.getElementById("havaDurumu").innerText = "☁️ No data";
      });

    function parseSaat(saatStr) {
      const [saat, dakika] = saatStr.split(":").map(Number);
      const hedef = new Date();
      hedef.setHours(saat, dakika, 0, 0);
      return hedef;
    }

    function guncelVakitSec() {
      const simdi = new Date();
      const vakitler = document.querySelectorAll(".saat-kutu");
      let sonraki = null;

      vakitler.forEach(kutu => {
        const hedefZaman = parseSaat(kutu.dataset.saat);
        if (!sonraki && hedefZaman > simdi) {
          sonraki = kutu;
        }
      });

      if (!sonraki) sonraki = vakitler[0];

      document.querySelectorAll(".vakit-kapsayici").forEach(span => {
        span.style.display = "none";
      });

      sonraki.parentElement.style.display = "flex";
      sonraki.style.backgroundColor = '#ff9900';
      sonraki.style.color = 'white';
    }

    guncelVakitSec();

    fetch("/istatistik")
      .then(res => res.json())
      .then(data => {
        document.getElementById("toplam").textContent = data.toplam;
        document.getElementById("online").textContent = data.online;
      });
  </script>
</body>
</html>